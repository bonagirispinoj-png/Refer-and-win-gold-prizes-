<script>
/* ============================================================
   CONFIG
============================================================ */
const firebaseConfig = {
  apiKey: "AIzaSyBIebPXVjzVBZl380ZCELg2LUSCLr-6QrE",
  authDomain: "neurocoin-ntc.firebaseapp.com",
  projectId: "neurocoin-ntc",
  storageBucket: "neurocoin-ntc.firebasestorage.app",
  messagingSenderId: "1040732555800",
  appId: "1:1040732555800:web:55e63b5ff81781c6b1916d"
};
firebase.initializeApp(firebaseConfig);
const auth = firebase.auth();
const db   = firebase.firestore();

const ADMIN_EMAIL   = "bonagirispinoj@gmail.com";
const RATE_PER_KM   = 2;          // ₹2 per km
const MIN_KM_SAVE   = 0.5;        // minimum km to credit
const REF_BONUS     = 10;         // ₹10 referral bonus each side
const DAILY_GOAL_KM = 5;

/* ============================================================
   STATE
============================================================ */
let currentUser = null;
let userData    = {};
let walkActive  = false;
let walkStart   = null;
let watchId     = null;
let lastPos     = null;
let sessionKm   = 0;
let sessionSteps = 0;
let walkTimer   = null;
let walkSeconds = 0;

/* ============================================================
   AUTH HELPERS
============================================================ */
function authTabSwitch(tab) {
  document.getElementById('loginForm').style.display    = tab === 'login'    ? 'block' : 'none';
  document.getElementById('registerForm').style.display = tab === 'register' ? 'block' : 'none';
  document.getElementById('tabLogin').classList.toggle('active', tab === 'login');
  document.getElementById('tabRegister').classList.toggle('active', tab === 'register');
}

async function register() {
  const name = document.getElementById('regName').value.trim();
  const email = document.getElementById('regEmail').value.trim();
  const pass  = document.getElementById('regPassword').value;
  const ref   = document.getElementById('regRef').value.trim().toUpperCase();

  if (!name)           return showToast('Enter your name');
  if (!email || !email.includes('@')) return showToast('Enter a valid email');
  if (pass.length < 6) return showToast('Password must be at least 6 characters');

  try {
    const cred = await auth.createUserWithEmailAndPassword(email, pass);
    await cred.user.updateProfile({ displayName: name });
    await initNewUser(cred.user, name, ref);
    showToast('Welcome to Health is Wealth! 🎉');
  } catch (e) {
    const msg = {
      'auth/email-already-in-use': 'Email already registered. Try logging in.',
      'auth/invalid-email': 'Invalid email address',
      'auth/weak-password': 'Password too weak'
    }[e.code] || e.message;
    showToast(msg);
  }
}

async function login() {
  const email = document.getElementById('loginEmail').value.trim();
  const pass  = document.getElementById('loginPassword').value;
  if (!email || !pass) return showToast('Enter email and password');
  try {
    await auth.signInWithEmailAndPassword(email, pass);
  } catch (e) {
    const msg = {
      'auth/user-not-found': 'No account found with this email',
      'auth/wrong-password': 'Incorrect password',
      'auth/invalid-credential': 'Incorrect email or password',
      'auth/too-many-requests': 'Too many attempts. Try again later.'
    }[e.code] || e.message;
    showToast(msg);
  }
}

async function googleLogin() {
  try {
    const provider = new firebase.auth.GoogleAuthProvider();
    const cred = await auth.signInWithPopup(provider);
    const snap = await db.collection('users').doc(cred.user.uid).get();
    if (!snap.exists) {
      await initNewUser(cred.user, cred.user.displayName || 'Walker', '');
    }
  } catch (e) {
    if (e.code !== 'auth/popup-closed-by-user') showToast(e.message || 'Google login failed');
  }
}

function logout() {
  if (walkActive) stopWalk(false);
  auth.signOut();
}

/* ============================================================
   USER INIT & LOAD
============================================================ */
function generateRefCode(uid) {
  return uid.slice(0,6).toUpperCase();
}

async function initNewUser(user, displayName, refCode) {
  const myRef = generateRefCode(user.uid);
  const now   = firebase.firestore.FieldValue.serverTimestamp();
  const data  = {
    uid: user.uid,
    email: user.email || '',
    name: displayName || user.displayName || 'Walker',
    refCode: myRef,
    referredBy: refCode || '',
    wallet: 0,
    totalEarned: 0,
    totalWithdrawn: 0,
    totalKm: 0,
    totalSteps: 0,
    referralCount: 0,
    walkDays: 0,
    createdAt: now
  };
  await db.collection('users').doc(user.uid).set(data);

  // Handle referral bonus
  if (refCode) {
    const refSnap = await db.collection('users').where('refCode', '==', refCode).limit(1).get();
    if (!refSnap.empty) {
      const refDoc = refSnap.docs[0];
      const batch  = db.batch();
      // Credit referrer
      batch.update(db.collection('users').doc(refDoc.id), {
        wallet: firebase.firestore.FieldValue.increment(REF_BONUS),
        totalEarned: firebase.firestore.FieldValue.increment(REF_BONUS),
        referralCount: firebase.firestore.FieldValue.increment(1)
      });
      batch.set(db.collection('transactions').doc(), {
        uid: refDoc.id, type: 'referral', amount: REF_BONUS,
        note: `Referral bonus — ${data.name} joined`, createdAt: now
      });
      // Credit new user
      batch.update(db.collection('users').doc(user.uid), {
        wallet: firebase.firestore.FieldValue.increment(REF_BONUS),
        totalEarned: firebase.firestore.FieldValue.increment(REF_BONUS)
      });
      batch.set(db.collection('transactions').doc(), {
        uid: user.uid, type: 'referral', amount: REF_BONUS,
        note: 'Welcome bonus — joined with referral', createdAt: now
      });
      await batch.commit();
    } else {
      showToast('Referral code not found — joined without bonus');
    }
  }
}

async function loadUserData(user) {
  try {
    const snap = await db.collection('users').doc(user.uid).get();
    if (snap.exists) {
      userData = snap.data();
    } else {
