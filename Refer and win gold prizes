async function loadLeaderboard() {
  const el = document.getElementById('lbContent');
  el.innerHTML = '<div class="spinner"></div>';
  try {
    const snap = await db.collection('users').orderBy('totalKm', 'desc').limit(20).get();
    const users = [];
    snap.forEach(d => users.push({ id: d.id, ...d.data() }));

    if (!users.length) { el.innerHTML = '<div class="empty"><div class="empty-icon">🏃</div><div class="empty-text">No walkers yet</div><div class="empty-sub">Be the first!</div></div>'; return; }

    let html = '';
    // Podium (top 3)
    if (users.length >= 3) {
      html += `<div class="lb-podium">
        <div class="podium-item podium-2">${podiumBlock(users[1], 2, '🥈')}</div>
        <div class="podium-item podium-1">${podiumBlock(users[0], 1, '🥇')}</div>
        <div class="podium-item podium-3">${podiumBlock(users[2], 3, '🥉')}</div>
      </div>`;
    }

    html += '<div class="lb-list">';
    users.forEach((u, i) => {
      const isMe = currentUser && u.id === currentUser.uid;
      html += `<div class="lb-row${isMe ? ' me' : ''}">
        <div class="lb-rank">${i+1}</div>
        <div class="lb-avatar">${(u.name||'W')[0].toUpperCase()}</div>
        <div class="lb-info">
          <div class="lb-name">${u.name || 'Walker'}${isMe ? ' <span style="font-size:11px;color:var(--green-mid);">(You)</span>' : ''}</div>
          <div class="lb-sub">${u.referralCount || 0} referrals • ${u.walkDays||0} days</div>
        </div>
        <div class="lb-km">${(u.totalKm||0).toFixed(1)}<span>km total</span></div>
      </div>`;
    });
    html += '</div>';
    el.innerHTML = html;
  } catch (e) {
    el.innerHTML = '<div class="empty"><div class="empty-icon">⚠️</div><div class="empty-text">Could not load leaderboard</div></div>';
  }
}

function podiumBlock(u, rank, medal) {
  return `<div class="podium-avatar" style="${rank===1?'width:56px;height:56px;font-size:24px;':''}">${(u.name||'W')[0].toUpperCase()}</div>
    <div class="podium-name">${(u.name||'Walker').split(' ')[0]}</div>
    <div class="podium-km">${(u.totalKm||0).toFixed(1)}km</div>
    <div class="podium-block" style="margin-top:6px;">${medal}</div>`;
}

