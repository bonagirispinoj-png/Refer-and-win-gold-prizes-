<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <title>Health is Wealth — Walk, Earn & Win</title>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700;800&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&display=swap" rel="stylesheet">

  <script src="https://www.gstatic.com/firebasejs/9.23.0/firebase-app-compat.js"></script>
  <script src="https://www.gstatic.com/firebasejs/9.23.0/firebase-auth-compat.js"></script>
  <script src="https://www.gstatic.com/firebasejs/9.23.0/firebase-firestore-compat.js"></script>

  <style>
    /* ===== DESIGN TOKENS ===== */
    :root {
      --green-deep:   #0a5c2a;
      --green-mid:    #1a9c4e;
      --green-bright: #22c55e;
      --green-pale:   #dcfce7;
      --gold:         #f5a623;
      --gold-pale:    #fff7e6;
      --danger:       #ef4444;
      --bg:           #f0faf4;
      --card:         #ffffff;
      --border:       #d1fae5;
      --text:         #062113;
      --muted:        #5a7a65;
      --nav-h:        68px;
      --header-h:     60px;
      --radius:       16px;
      --shadow:       0 4px 24px rgba(10,92,42,0.10);
      --shadow-lg:    0 8px 40px rgba(10,92,42,0.16);
    }

    /* ===== RESET & BASE ===== */
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; -webkit-tap-highlight-color: transparent; }
    html { scroll-behavior: smooth; }
    body { font-family: 'DM Sans', sans-serif; background: var(--bg); color: var(--text); min-height: 100dvh; overflow-x: hidden; }
    input, button, select { font-family: inherit; }
    input:focus { outline: 2px solid var(--green-mid); outline-offset: 2px; }

    /* ===== SCROLLBAR ===== */
    ::-webkit-scrollbar { width: 4px; }
    ::-webkit-scrollbar-track { background: transparent; }
    ::-webkit-scrollbar-thumb { background: var(--green-pale); border-radius: 99px; }

    /* ===== HEADER ===== */
    .app-header {
      position: fixed; top: 0; left: 0; right: 0; z-index: 500;
      height: var(--header-h);
      background: rgba(255,255,255,0.92);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid var(--border);
      display: flex; align-items: center; justify-content: space-between;
      padding: 0 16px;
    }
    .brand { display: flex; align-items: center; gap: 8px; }
    .brand-icon { width: 34px; height: 34px; background: var(--green-deep); border-radius: 10px; display: flex; align-items: center; justify-content: center; font-size: 18px; }
    .brand-name { font-family: 'Playfair Display', serif; font-size: 17px; font-weight: 700; color: var(--green-deep); letter-spacing: -0.3px; }
    .wallet-chip {
      display: flex; align-items: center; gap: 6px;
      background: var(--green-deep); color: #fff;
      padding: 7px 14px; border-radius: 50px;
      font-size: 14px; font-weight: 700; letter-spacing: 0.3px;
      box-shadow: 0 2px 12px rgba(10,92,42,0.25);
      transition: transform 0.15s;
    }
    .wallet-chip:active { transform: scale(0.97); }

    /* ===== SCROLL BODY ===== */
    .scroll-body {
      padding-top: calc(var(--header-h) + 12px);
      padding-bottom: calc(var(--nav-h) + 16px);
      min-height: 100dvh;
    }
    .container { max-width: 500px; margin: 0 auto; padding: 0 14px; }

    /* ===== BOTTOM NAV ===== */
    .nav-bar {
      position: fixed; bottom: 0; left: 0; right: 0; z-index: 500;
      height: var(--nav-h);
      background: rgba(255,255,255,0.95);
      backdrop-filter: blur(16px);
      border-top: 1px solid var(--border);
      display: flex; align-items: center;
    }
    .nav-item {
      flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: center;
      gap: 3px; cursor: pointer; border: none; background: none;
      padding: 8px 0; transition: all 0.2s; border-radius: 0;
      color: var(--muted); font-size: 10px; font-weight: 500;
    }
    .nav-item .nav-icon { font-size: 22px; line-height: 1; transition: transform 0.2s; }
    .nav-item.active { color: var(--green-deep); }
    .nav-item.active .nav-icon { transform: translateY(-2px); }
    .nav-admin { background: var(--green-deep); color: #fff !important; border-radius: 12px; margin: 8px 6px; font-size: 10px; padding: 4px 8px; }
    .nav-admin.active { background: var(--gold); color: #000 !important; }

    /* ===== SECTIONS ===== */
    .section { display: none; }
    .section.active { display: block; animation: fadeSlide 0.3s ease; }
    @keyframes fadeSlide { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: translateY(0); } }

    /* ===== AUTH SCREEN ===== */
    #authScreen {
      min-height: 100dvh;
      display: flex; flex-direction: column; align-items: center; justify-content: center;
      padding: 24px;
      background: linear-gradient(160deg, #e6f9ef 0%, #f0faf4 40%, #fff7e6 100%);
    }
    #authScreen.section { display: flex; }
    #authScreen.section:not(.active) { display: none; }
    .auth-logo { font-size: 64px; margin-bottom: 12px; animation: bounce 2s infinite; }
    @keyframes bounce { 0%,100% { transform: translateY(0); } 50% { transform: translateY(-10px); } }
    .auth-title { font-family: 'Playfair Display', serif; font-size: 28px; font-weight: 800; color: var(--green-deep); text-align: center; margin-bottom: 4px; }
    .auth-sub { color: var(--muted); font-size: 14px; text-align: center; margin-bottom: 32px; }
    .auth-card { width: 100%; max-width: 380px; background: white; border-radius: 24px; padding: 28px; box-shadow: var(--shadow-lg); }
    .auth-tabs { display: flex; background: var(--bg); border-radius: 12px; padding: 4px; margin-bottom: 24px; }
    .auth-tab { flex: 1; padding: 8px; border: none; background: none; border-radius: 9px; font-weight: 600; font-size: 14px; cursor: pointer; color: var(--muted); transition: all 0.2s; }
    .auth-tab.active { background: white; color: var(--green-deep); box-shadow: 0 2px 8px rgba(0,0,0,0.08); }
    .input-field {
      width: 100%; padding: 13px 14px; margin: 6px 0;
      border: 1.5px solid var(--border); border-radius: 12px;
      font-size: 15px; background: var(--bg); transition: border-color 0.2s;
    }
    .input-field:focus { border-color: var(--green-mid); background: white; }
    .ref-hint { font-size: 12px; color: var(--muted); margin: 2px 0 8px 2px; }
    .divider { display: flex; align-items: center; gap: 12px; margin: 16px 0; color: var(--muted); font-size: 13px; }
    .divider::before, .divider::after { content: ''; flex: 1; height: 1px; background: var(--border); }

    /* ===== BUTTONS ===== */
    .btn { width: 100%; padding: 14px; border: none; border-radius: 12px; font-size: 15px; font-weight: 700; cursor: pointer; transition: all 0.18s; letter-spacing: 0.2px; }
    .btn:active { transform: scale(0.98); }
    .btn-primary { background: var(--green-mid); color: white; box-shadow: 0 4px 16px rgba(26,156,78,0.30); }
    .btn-primary:hover { background: var(--green-deep); }
    .btn-gold { background: var(--gold); color: #000; box-shadow: 0 4px 16px rgba(245,166,35,0.30); }
    .btn-danger { background: var(--danger); color: white; }
    .btn-outline { background: transparent; border: 2px solid var(--green-mid); color: var(--green-mid); }
    .btn-google { background: white; color: #333; border: 2px solid #e0e0e0; display: flex; align-items: center; justify-content: center; gap: 10px; }
    .google-icon { width: 18px; height: 18px; }
    .btn-sm { padding: 9px 18px; width: auto; font-size: 13px; border-radius: 9px; }

    /* ===== CARDS ===== */
    .card { background: var(--card); border-radius: var(--radius); padding: 20px; margin-bottom: 14px; box-shadow: var(--shadow); border: 1px solid var(--border); }
    .card-title { font-family: 'Playfair Display', serif; font-size: 16px; font-weight: 700; color: var(--green-deep); margin-bottom: 14px; }

    /* ===== HOME TAB ===== */
    .hero-card {
      background: linear-gradient(135deg, var(--green-deep) 0%, var(--green-mid) 100%);
      border-radius: 20px; padding: 24px; margin-bottom: 14px;
      color: white; position: relative; overflow: hidden;
      box-shadow: 0 8px 32px rgba(10,92,42,0.30);
    }
    .hero-card::before {
      content: '🌿'; position: absolute; right: -10px; top: -10px;
      font-size: 90px; opacity: 0.15; transform: rotate(20deg);
    }
    .hero-greeting { font-size: 13px; opacity: 0.85; margin-bottom: 4px; }
    .hero-balance { font-family: 'Playfair Display', serif; font-size: 38px; font-weight: 800; line-height: 1; }
    .hero-balance span { font-size: 20px; font-weight: 600; vertical-align: super; margin-right: 2px; }
    .hero-sub { font-size: 12px; opacity: 0.75; margin-top: 4px; }
    .hero-stats { display: flex; gap: 12px; margin-top: 20px; }
    .hero-stat { flex: 1; background: rgba(255,255,255,0.15); border-radius: 12px; padding: 10px 12px; }
    .hero-stat-val { font-size: 18px; font-weight: 700; }
    .hero-stat-lbl { font-size: 10px; opacity: 0.8; margin-top: 2px; }

    /* Walk Controls */
    .walk-card { text-align: center; }
    .walk-btn-wrap { position: relative; display: inline-block; margin: 8px 0 16px; }
    .walk-btn-ring {
      width: 130px; height: 130px; border-radius: 50%;
      background: conic-gradient(var(--green-bright) var(--progress, 0%), var(--green-pale) 0%);
      display: flex; align-items: center; justify-content: center;
      cursor: pointer; transition: transform 0.2s;
      box-shadow: 0 6px 24px rgba(34,197,94,0.30);
    }
    .walk-btn-ring:active { transform: scale(0.95); }
    .walk-btn-inner {
      width: 106px; height: 106px; border-radius: 50%;
      background: white; display: flex; flex-direction: column;
      align-items: center; justify-content: center; gap: 2px;
    }
    .walk-btn-icon { font-size: 32px; line-height: 1; transition: transform 0.3s; }
    .walk-btn-label { font-size: 12px; font-weight: 700; color: var(--green-deep); }
    .walk-stats-row { display: flex; gap: 10px; justify-content: center; }
    .walk-stat-box { flex: 1; background: var(--green-pale); border-radius: 12px; padding: 12px 8px; text-align: center; }
    .walk-stat-val { font-size: 18px; font-weight: 700; color: var(--green-deep); }
    .walk-stat-lbl { font-size: 10px; color: var(--muted); margin-top: 2px; }
    .walk-earning-note { font-size: 12px; color: var(--muted); margin-top: 10px; }

    /* Today's Activity */
    .today-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
    .today-cell { background: var(--bg); border-radius: 12px; padding: 14px; text-align: center; }
    .today-cell-val { font-size: 22px; font-weight: 700; color: var(--green-deep); }
    .today-cell-lbl { font-size: 11px; color: var(--muted); margin-top: 4px; }

    /* Referral Mini */
    .ref-banner {
      background: linear-gradient(135deg, #fff7e6, #fff);
      border: 1.5px solid #fde68a; border-radius: var(--radius);
      padding: 16px; display: flex; align-items: center; gap: 14px;
      cursor: pointer; transition: transform 0.15s;
    }
    .ref-banner:active { transform: scale(0.98); }
    .ref-banner-icon { font-size: 32px; flex-shrink: 0; }
    .ref-banner-title { font-weight: 700; font-size: 14px; color: #92400e; }
    .ref-banner-sub { font-size: 12px; color: #b45309; margin-top: 2px; }

    /* ===== LEADERBOARD ===== */
    .lb-podium { display: flex; align-items: flex-end; justify-content: center; gap: 10px; margin-bottom: 20px; height: 130px; }
    .podium-item { display: flex; flex-direction: column; align-items: center; flex: 1; }
    .podium-avatar { width: 48px; height: 48px; border-radius: 50%; background: var(--green-pale); display: flex; align-items: center; justify-content: center; font-size: 22px; font-weight: 700; color: var(--green-deep); border: 3px solid white; box-shadow: 0 2px 12px rgba(0,0,0,0.10); }
    .podium-name { font-size: 11px; font-weight: 600; margin-top: 4px; text-align: center; max-width: 64px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .podium-km { font-size: 10px; color: var(--muted); }
    .podium-block { border-radius: 10px 10px 0 0; width: 100%; display: flex; align-items: center; justify-content: center; font-size: 20px; }
    .podium-1 .podium-block { height: 80px; background: linear-gradient(180deg, #ffd700, #f59e0b); }
    .podium-2 .podium-block { height: 60px; background: linear-gradient(180deg, #c0c0c0, #9ca3af); }
    .podium-3 .podium-block { height: 48px; background: linear-gradient(180deg, #cd7f32, #b45309); }
    .podium-1 .podium-avatar { border-color: #fbbf24; }
    .lb-list { }
    .lb-row {
      display: flex; align-items: center; gap: 12px;
      padding: 13px 14px; background: white; border-radius: 12px;
      margin-bottom: 8px; border: 1px solid var(--border);
      transition: transform 0.15s;
    }
    .lb-row.me { background: var(--green-pale); border-color: var(--green-mid); }
    .lb-rank { width: 26px; text-align: center; font-weight: 700; color: var(--muted); font-size: 13px; }
    .lb-avatar { width: 38px; height: 38px; border-radius: 50%; background: var(--green-pale); display: flex; align-items: center; justify-content: center; font-size: 16px; font-weight: 700; color: var(--green-deep); flex-shrink: 0; }
    .lb-info { flex: 1; }
    .lb-name { font-weight: 600; font-size: 14px; }
    .lb-sub { font-size: 11px; color: var(--muted); margin-top: 2px; }
    .lb-km { font-weight: 700; color: var(--green-deep); font-size: 14px; text-align: right; }
    .lb-km span { font-size: 10px; font-weight: 400; color: var(--muted); display: block; }

    /* ===== WALLET TAB ===== */
    .balance-hero {
      background: linear-gradient(135deg, var(--green-deep), #0d7a38);
      border-radius: 20px; padding: 28px 24px; text-align: center;
      color: white; margin-bottom: 14px; position: relative; overflow: hidden;
      box-shadow: 0 8px 32px rgba(10,92,42,0.28);
    }
    .balance-hero::after { content: '₹'; position: absolute; right: 10px; top: -10px; font-size: 100px; opacity: 0.07; font-family: 'Playfair Display', serif; }
    .balance-label { font-size: 13px; opacity: 0.8; }
    .balance-amt { font-family: 'Playfair Display', serif; font-size: 48px; font-weight: 800; line-height: 1.1; margin: 8px 0; }
    .balance-note { font-size: 12px; opacity: 0.7; }
    .balance-row { display: flex; gap: 10px; margin-top: 16px; }
    .balance-mini { flex: 1; background: rgba(255,255,255,0.15); border-radius: 12px; padding: 10px; text-align: center; }
    .balance-mini-val { font-size: 16px; font-weight: 700; }
    .balance-mini-lbl { font-size: 10px; opacity: 0.75; margin-top: 2px; }

    /* Withdraw form */
    .section-label { font-size: 13px; font-weight: 600; color: var(--muted); text-transform: uppercase; letter-spacing: 0.8px; margin-bottom: 10px; }
    .amt-chips { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 12px; }
    .amt-chip { padding: 7px 14px; border: 1.5px solid var(--border); border-radius: 50px; background: white; font-size: 13px; font-weight: 600; cursor: pointer; color: var(--green-deep); transition: all 0.15s; }
    .amt-chip.selected, .amt-chip:hover { background: var(--green-deep); color: white; border-color: var(--green-deep); }

    /* Txn History */
    .txn-row { display: flex; align-items: center; gap: 12px; padding: 13px 0; border-bottom: 1px solid var(--bg); }
    .txn-icon { width: 40px; height: 40px; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 18px; flex-shrink: 0; }
    .txn-icon.earn { background: var(--green-pale); }
    .txn-icon.spend { background: #fef2f2; }
    .txn-icon.ref { background: var(--gold-pale); }
    .txn-info { flex: 1; }
    .txn-title { font-weight: 600; font-size: 14px; }
    .txn-date { font-size: 11px; color: var(--muted); margin-top: 2px; }
    .txn-amt { font-weight: 700; font-size: 15px; }
    .txn-amt.plus { color: var(--green-mid); }
    .txn-amt.minus { color: var(--danger); }
    .txn-amt.pend { color: var(--gold); }

    /* ===== PROFILE TAB ===== */
    .profile-avatar-wrap { text-align: center; margin-bottom: 20px; }
    .profile-avatar {
      width: 80px; height: 80px; border-radius: 50%;
      background: linear-gradient(135deg, var(--green-mid), var(--green-deep));
      margin: 0 auto 10px; display: flex; align-items: center; justify-content: center;
      font-size: 36px; color: white; font-weight: 700;
      box-shadow: 0 6px 24px rgba(26,156,78,0.30);
    }
    .profile-name { font-family: 'Playfair Display', serif; font-size: 20px; font-weight: 700; }
    .profile-email { font-size: 13px; color: var(--muted); margin-top: 3px; }
    .profile-stats { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 10px; margin-bottom: 14px; }
    .profile-stat { background: var(--bg); border-radius: 12px; padding: 14px 10px; text-align: center; }
    .profile-stat-val { font-size: 20px; font-weight: 700; color: var(--green-deep); }
    .profile-stat-lbl { font-size: 10px; color: var(--muted); margin-top: 4px; }

    .ref-code-box {
      background: var(--green-pale); border-radius: 12px; padding: 16px;
      display: flex; align-items: center; justify-content: space-between;
      border: 1.5px dashed var(--green-mid);
    }
    .ref-code-label { font-size: 12px; color: var(--muted); margin-bottom: 3px; }
    .ref-code-val { font-family: monospace; font-size: 22px; font-weight: 800; color: var(--green-deep); letter-spacing: 2px; }
    .ref-copy-btn { background: var(--green-deep); color: white; border: none; border-radius: 9px; padding: 9px 14px; font-size: 13px; font-weight: 600; cursor: pointer; }

    .menu-list { }
    .menu-item {
      display: flex; align-items: center; gap: 14px; padding: 15px 16px;
      background: white; border-radius: 12px; margin-bottom: 8px;
      cursor: pointer; border: 1px solid var(--border); transition: all 0.15s;
    }
    .menu-item:active { background: var(--bg); }
    .menu-item-icon { width: 38px; height: 38px; border-radius: 10px; background: var(--green-pale); display: flex; align-items: center; justify-content: center; font-size: 18px; }
    .menu-item-text { flex: 1; }
    .menu-item-title { font-weight: 600; font-size: 14px; }
    .menu-item-sub { font-size: 12px; color: var(--muted); margin-top: 2px; }
    .menu-item-arrow { color: var(--muted); font-size: 16px; }

    /* ===== ADMIN PANEL ===== */
    .admin-header { background: linear-gradient(135deg, #1a1a2e, #16213e); border-radius: 16px; padding: 20px; margin-bottom: 14px; color: white; }
    .admin-title { font-family: 'Playfair Display', serif; font-size: 20px; font-weight: 700; }
    .admin-sub { font-size: 13px; opacity: 0.7; margin-top: 4px; }
    .admin-stats { display: flex; gap: 10px; margin-top: 14px; }
    .admin-stat { flex: 1; background: rgba(255,255,255,0.1); border-radius: 10px; padding: 10px; text-align: center; }
    .admin-stat-val { font-size: 20px; font-weight: 700; }
    .admin-stat-lbl { font-size: 10px; opacity: 0.7; margin-top: 2px; }
    .withdrawal-card { background: white; border-radius: 12px; padding: 16px; margin-bottom: 10px; border: 1px solid var(--border); }
    .w-row { display: flex; justify-content: space-between; align-items: center; margin-bottom: 6px; }
    .w-amt { font-size: 20px; font-weight: 800; color: var(--green-deep); }
    .w-badge { padding: 4px 10px; border-radius: 50px; font-size: 11px; font-weight: 700; }
    .w-badge.pending { background: #fef9c3; color: #854d0e; }
    .w-badge.approved { background: var(--green-pale); color: var(--green-deep); }
    .w-badge.rejected { background: #fef2f2; color: var(--danger); }
    .w-info { font-size: 12px; color: var(--muted); margin-bottom: 10px; }
    .w-actions { display: flex; gap: 8px; }

    /* ===== MODAL ===== */
    .modal-overlay {
      position: fixed; inset: 0; background: rgba(0,0,0,0.45);
      backdrop-filter: blur(6px); z-index: 800;
      display: flex; align-items: flex-end; justify-content: center;
      opacity: 0; pointer-events: none; transition: opacity 0.25s;
    }
    .modal-overlay.open { opacity: 1; pointer-events: all; }
    .modal-sheet {
      background: white; border-radius: 24px 24px 0 0;
      padding: 24px; width: 100%; max-width: 500px;
      transform: translateY(100%); transition: transform 0.3s cubic-bezier(0.34,1.56,0.64,1);
      max-height: 90dvh; overflow-y: auto;
    }
    .modal-overlay.open .modal-sheet { transform: translateY(0); }
    .modal-handle { width: 36px; height: 4px; background: #e0e0e0; border-radius: 99px; margin: 0 auto 20px; }
    .modal-title { font-family: 'Playfair Display', serif; font-size: 20px; font-weight: 700; margin-bottom: 16px; color: var(--green-deep); }

    /* ===== TOAST ===== */
    #toast {
      position: fixed; bottom: calc(var(--nav-h) + 16px); left: 50%; transform: translateX(-50%) translateY(20px);
      background: #1a1a1a; color: white; padding: 12px 22px; border-radius: 50px;
      font-size: 14px; font-weight: 500; white-space: nowrap; z-index: 9999;
      opacity: 0; pointer-events: none; transition: all 0.3s; max-width: 90vw; text-align: center;
      box-shadow: 0 4px 20px rgba(0,0,0,0.25);
    }
    #toast.show { opacity: 1; transform: translateX(-50%) translateY(0); }

    /* ===== BADGE ===== */
    .badge-earn { display: inline-flex; align-items: center; gap: 5px; background: var(--green-pale); color: var(--green-deep); padding: 4px 10px; border-radius: 50px; font-size: 12px; font-weight: 700; }

    /* ===== LOADING ===== */
