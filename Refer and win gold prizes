async function submitWithdrawal() {
  const amt = parseFloat(document.getElementById('withdrawAmt').value);
  const upi = document.getElementById('withdrawUPI').value.trim();

  if (!amt || amt < 50) return showToast('Minimum withdrawal is ₹50');
  if (!upi || !upi.includes('@')) return showToast('Enter a valid UPI ID (e.g. name@upi)');
  if (amt > (userData.wallet || 0)) return showToast('Insufficient balance');

  try {
    const now = firebase.firestore.FieldValue.serverTimestamp();
    const batch = db.batch();
    batch.update(db.collection('users').doc(currentUser.uid), {
      wallet: firebase.firestore.FieldValue.increment(-amt),
      totalWithdrawn: firebase.firestore.FieldValue.increment(amt),
      pendingPayout:  firebase.firestore.FieldValue.increment(amt)
    });
    const wRef = db.collection('withdrawals').doc();
    batch.set(wRef, {
      uid: currentUser.uid, email: userData.email, name: userData.name,
      amount: amt, upi, status: 'pending', createdAt: now
    });
    batch.set(db.collection('transactions').doc(), {
      uid: currentUser.uid, type: 'withdrawal', amount: -amt,
      note: `Withdrawal to ${upi}`, status: 'pending', createdAt: now
    });
    await batch.commit();
    document.getElementById('withdrawAmt').value = '';
    document.getElementById('withdrawUPI').value = '';
    document.querySelectorAll('.amt-chip').forEach(c => c.classList.remove('selected'));
    showToast(`Withdrawal of ₹${amt} requested! ✅`);
    await loadUserData(currentUser);
    loadTransactions();
  } catch (e) { showToast('Error: ' + e.message); }
}

async function loadTransactions() {
  const el = document.getElementById('txnList');
  el.innerHTML = '<div class="spinner"></div>';
  try {
    const snap = await db.collection('transactions')
      .where('uid', '==', currentUser.uid)
      .orderBy('createdAt', 'desc')
      .limit(30).get();

    if (snap.empty) { el.innerHTML = '<div class="empty"><div class="empty-icon">📋</div><div class="empty-text">No transactions yet</div><div class="empty-sub">Start walking to earn!</div></div>'; return; }

    let html = '';
    snap.forEach(doc => {
      const t = doc.data();
      const icons = { walk: '🚶', referral: '🎁', withdrawal: '💸' };
      const cls   = t.amount > 0 ? 'earn' : 'spend';
      const amtCls = t.amount > 0 ? 'plus' : (t.status === 'pending' ? 'pend' : 'minus');
      const amtStr = (t.amount > 0 ? '+' : '') + '₹' + Math.abs(t.amount).toFixed(2);
      const date   = t.createdAt?.toDate ? t.createdAt.toDate().toLocaleDateString('en-IN', { day:'numeric', month:'short' }) : 'Just now';
      html += `<div class="txn-row">
        <div class="txn-icon ${cls}">${icons[t.type] || '💰'}</div>
        <div class="txn-info"><div class="txn-title">${t.note}</div><div class="txn-date">${date}${t.status === 'pending' ? ' · Pending' : ''}</div></div>
        <div class="txn-amt ${amtCls}">${amtStr}</div>
      </div>`;
    });
    el.innerHTML = html;
  } catch (e) {
    el.innerHTML = '<div style="color:var(--muted);font-size:13px;padding:12px 0;">Error loading transactions</div>';
  }
}

