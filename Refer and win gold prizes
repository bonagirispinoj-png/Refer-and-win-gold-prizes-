async function loadAdminPanel() {
  const el = document.getElementById('adminContent');
  el.innerHTML = '<div class="spinner"></div>';
  try {
    // Stats
    const [usersSnap, pendSnap, approvedSnap] = await Promise.all([
      db.collection('users').get(),
      db.collection('withdrawals').where('status','==','pending').get(),
      db.collection('withdrawals').where('status','==','approved').get()
    ]);
    document.getElementById('adminTotalUsers').textContent = usersSnap.size;
    document.getElementById('adminPending').textContent    = pendSnap.size;
    let paidOut = 0;
    approvedSnap.forEach(d => paidOut += d.data().amount || 0);
    document.getElementById('adminPaid').textContent = '₹' + paidOut;

    if (pendSnap.empty) { el.innerHTML = '<div class="empty"><div class="empty-icon">✅</div><div class="empty-text">No pending withdrawals</div></div>'; return; }

    let html = '';
    pendSnap.forEach(doc => {
      const d = doc.data();
      html += `<div class="withdrawal-card">
        <div class="w-row"><span class="w-amt">₹${d.amount}</span><span class="w-badge pending">Pending</span></div>
        <div class="w-info">👤 ${d.name} (${d.email})<br>💳 UPI: <strong>${d.upi}</strong></div>
        <div class="w-actions">
          <button class="btn btn-primary btn-sm" onclick="approveWithdrawal('${doc.id}','${currentUser.uid}',${d.amount},'${d.uid}')">✅ Approve</button>
          <button class="btn btn-danger btn-sm" onclick="rejectWithdrawal('${doc.id}','${d.uid}',${d.amount})">❌ Reject</button>
        </div>
      </div>`;
    });
    el.innerHTML = html;
  } catch (e) {
    el.innerHTML = '<div style="color:var(--danger);padding:12px;">Error: ' + e.message + '</div>';
  }
}

async function approveWithdrawal(wId, adminUid, amount, userUid) {
  try {
    const batch = db.batch();
    batch.update(db.collection('withdrawals').doc(wId), {
      status: 'approved',
      approvedAt: firebase.firestore.FieldValue.serverTimestamp()
    });
    // Deduct pendingPayout from user
    batch.update(db.collection('users').doc(userUid), {
      pendingPayout: firebase.firestore.FieldValue.increment(-amount)
    });
    await batch.commit();
    showToast(`₹${amount} withdrawal approved! ✅`);
    loadAdminPanel();
  } catch (e) { showToast('Error: ' + e.message); }
}

async function rejectWithdrawal(wId, userUid, amount) {
  if (!confirm('Reject and refund ₹' + amount + ' to user?')) return;
  try {
    const batch = db.batch();
    batch.update(db.collection('withdrawals').doc(wId), {
      status: 'rejected',
      rejectedAt: firebase.firestore.FieldValue.serverTimestamp()
    });
    // Refund wallet + deduct pending
    batch.update(db.collection('users').doc(userUid), {
      wallet: firebase.firestore.FieldValue.increment(amount),
      totalWithdrawn: firebase.firestore.FieldValue.increment(-amount),
      pendingPayout:  firebase.firestore.FieldValue.increment(-amount)
    });
    batch.set(db.collection('transactions').doc(), {
      uid: userUid, type: 'refund', amount,
      note: 'Withdrawal rejected — amount refunded',
      createdAt: firebase.firestore.FieldValue.serverTimestamp()
    });
    await batch.commit();
    showToast('Withdrawal rejected & refunded');
    loadAdminPanel();
  } catch (e) { showToast('Error: ' + e.message); }
}

