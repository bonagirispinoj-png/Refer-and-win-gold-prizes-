/* ============================================================
   WALK / GPS
============================================================ */
function toggleWalk() {
  if (walkActive) stopWalk(true);
  else startWalk();
}

function startWalk() {
  if (!navigator.geolocation) {
    showToast('GPS not supported on this device');
    return;
  }
  walkActive  = true;
  sessionKm   = 0;
  sessionSteps = 0;
  walkSeconds = 0;
  lastPos     = null;
  walkStart   = Date.now();

  document.getElementById('walkBtnIcon').textContent  = '🛑';
  document.getElementById('walkBtnLabel').textContent = 'TAP TO STOP';
  document.getElementById('walkNote').textContent     = '📍 GPS active — walk to earn';
  document.getElementById('walkBtn').style.setProperty('--progress', '0%');

  watchId = navigator.geolocation.watchPosition(onGPS, gpsErr, {
    enableHighAccuracy: true, maximumAge: 5000, timeout: 15000
  });

  walkTimer = setInterval(() => {
    walkSeconds++;
    const m = Math.floor(walkSeconds / 60);
    const s = walkSeconds % 60;
    document.getElementById('liveDuration').textContent = m + ':' + String(s).padStart(2,'0');
    // Rough step estimate: ~1.4 steps per second (avg walking cadence)
    sessionSteps = Math.round(sessionKm * 1300);
    document.getElementById('liveSteps').textContent = fmtNum(sessionSteps);
  }, 1000);

  showToast('Walk started! GPS is tracking 🚶');
}

function onGPS(pos) {
  const { latitude: lat, longitude: lon } = pos.coords;
  if (lastPos) {
    const d = haversine(lastPos.lat, lastPos.lon, lat, lon);
    if (d > 0.005 && d < 0.3) { // 5m to 300m per update (filter noise)
      sessionKm += d;
      document.getElementById('liveKm').textContent    = sessionKm.toFixed(2);
      document.getElementById('liveEarned').textContent = '₹' + (sessionKm * RATE_PER_KM).toFixed(2);
      const pct = Math.min(100, (sessionKm / DAILY_GOAL_KM) * 100);
      document.getElementById('walkBtn').style.setProperty('--progress', pct + '%');
    }
  }
  lastPos = { lat, lon };
}

function gpsErr(err) {
  const msgs = ['', 'GPS permission denied. Enable location to earn.', 'GPS position unavailable.', 'GPS timed out.'];
  showToast(msgs[err.code] || 'GPS error');
  if (err.code === 1) stopWalk(false);
}

async function stopWalk(save) {
  walkActive = false;
  clearInterval(walkTimer);
  if (watchId !== null) navigator.geolocation.clearWatch(watchId);
  watchId = null; lastPos = null;

  document.getElementById('walkBtnIcon').textContent  = '🚶';
  document.getElementById('walkBtnLabel').textContent = 'TAP TO START';
  document.getElementById('walkNote').textContent     = 'GPS tracking • ₹2 per km • Min 0.5 km to save';

  if (!save || sessionKm < MIN_KM_SAVE) {
    if (save) showToast('Walk too short (min 0.5 km). Not saved.');
    sessionKm = 0; sessionSteps = 0; walkSeconds = 0;
    document.getElementById('liveKm').textContent    = '0.00';
    document.getElementById('liveEarned').textContent = '₹0.00';
    document.getElementById('liveSteps').textContent = '0';
    document.getElementById('liveDuration').textContent = '0:00';
    return;
  }

  const earned = parseFloat((sessionKm * RATE_PER_KM).toFixed(2));
  const now    = firebase.firestore.FieldValue.serverTimestamp();
  const today  = new Date().toDateString();

  try {
    const snap = await db.collection('users').doc(currentUser.uid).get();
    const d    = snap.data();
    const lastWalkDay = d.lastWalkDay || '';
    const isNewDay    = lastWalkDay !== today;

    await db.collection('users').doc(currentUser.uid).update({
      wallet:         firebase.firestore.FieldValue.increment(earned),
      totalEarned:    firebase.firestore.FieldValue.increment(earned),
      totalKm:        firebase.firestore.FieldValue.increment(sessionKm),
      totalSteps:     firebase.firestore.FieldValue.increment(sessionSteps),
      todayKm:        isNewDay ? sessionKm : firebase.firestore.FieldValue.increment(sessionKm),
      todaySteps:     isNewDay ? sessionSteps : firebase.firestore.FieldValue.increment(sessionSteps),
      todayEarned:    isNewDay ? earned : firebase.firestore.FieldValue.increment(earned),
      walkDays:       isNewDay ? firebase.firestore.FieldValue.increment(1) : (d.walkDays || 0),
      lastWalkDay:    today
    });

    await db.collection('transactions').add({
      uid: currentUser.uid, type: 'walk', amount: earned,
      km: sessionKm, steps: sessionSteps,
      note: `Walked ${sessionKm.toFixed(2)} km`, createdAt: now
    });

    showToast(`Great walk! Earned ₹${earned.toFixed(2)} 💰`);
    await loadUserData(currentUser);
  } catch (e) {
    showToast('Error saving walk: ' + e.message);
  }

  sessionKm = 0; sessionSteps = 0; walkSeconds = 0;
  document.getElementById('liveKm').textContent     = '0.00';
  document.getElementById('liveEarned').textContent = '₹0.00';
  document.getElementById('liveSteps').textContent  = '0';
  document.getElementById('liveDuration').textContent = '0:00';
  document.getElementById('walkBtn').style.setProperty('--progress', '0%');
}

function haversine(lat1, lon1, lat2, lon2) {
  const R = 6371;
  const dLat = (lat2 - lat1) * Math.PI / 180;
  const dLon = (lon2 - lon1) * Math.PI / 180;
  const a = Math.sin(dLat/2)**2 + Math.cos(lat1*Math.PI/180) * Math.cos(lat2*Math.PI/180) * Math.sin(dLon/2)**2;
  return R * 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1-a));
}

